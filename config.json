{
  "base_url": "https://api.example.com",
  "timeout": 30,
  "default_headers": {
    "Content-Type": "application/json",
    "User-Agent": "API-Client/1.0"
  },
  "auth": {
    "type": "bearer",
    "token": "your_token_here"
  },
  "endpoints": {
    "get_users": {
      "method": "GET",
      "path": "/users"
    },
    "create_user": {
      "method": "POST",
      "path": "/users",
      "headers": {
        "X-Custom-Header": "value"
      }
    },
    "update_user": {
      "method": "PUT",
      "path": "/users/{id}",
      "params": {
        "notify": "true"
      }
    },
    "delete_user": {
      "method": "DELETE",
      "path": "/users/{id}"
    }
  }
}
